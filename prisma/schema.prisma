// A1NT — A1 Integrations Business Operations Platform
// Core data models for CRM, project management, invoicing, and module system

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// AUTH & USERS
// ============================================================================

enum UserRole {
  SUPER_ADMIN    // A1 Integrations staff
  OWNER          // Client business owner
  ADMIN          // Client admin user
  MANAGER        // Client manager
  EMPLOYEE       // Client employee / technician
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  role          UserRole  @default(EMPLOYEE)
  avatarUrl     String?
  phone         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  assignedTasks  Task[]        @relation("AssignedTo")
  createdTasks   Task[]        @relation("CreatedBy")
  invoicesCreated Invoice[]
  activityLogs   ActivityLog[]
  sessions       Session[]

  @@index([organizationId])
  @@index([email])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
}

// ============================================================================
// ORGANIZATIONS (Client Businesses)
// ============================================================================

enum IndustryType {
  PLUMBING_HVAC
  AUTO_REPAIR
  RESTAURANT
  CLEANING_SERVICE
  LANDSCAPING
  MANUFACTURING
  WHOLESALE_DISTRIBUTION
  LODGING_HOSPITALITY
  GAS_STATION_CSTORE
  BOOKKEEPING_ACCOUNTING
  OTHER
}

model Organization {
  id            String       @id @default(cuid())
  name          String
  industry      IndustryType
  description   String?
  phone         String?
  email         String?
  website       String?
  address       String?
  city          String?
  state         String?
  zip           String?
  employeeCount Int?
  annualRevenue Float?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Template & module configuration
  templateId    String?
  template      Template?    @relation(fields: [templateId], references: [id])

  // Relations
  users         User[]
  clients       Client[]
  employees     Employee[]
  invoices      Invoice[]
  tasks         Task[]
  modules       OrganizationModule[]
  activityLogs  ActivityLog[]

  @@index([industry])
}

// ============================================================================
// TEMPLATES & MODULES (Core A1NT Product)
// ============================================================================

model Template {
  id           String    @id @default(cuid())
  name         String    // e.g., "Plumbing & HVAC Services"
  slug         String    @unique
  industry     IndustryType
  description  String?
  version      String    @default("1.0.0")
  isPublished  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  modules       TemplateModule[]
  organizations Organization[]
}

model Module {
  id           String    @id @default(cuid())
  name         String    // e.g., "AI Receptionist & Call Handling"
  slug         String    @unique
  description  String?
  category     String    // e.g., "Communication", "Operations", "Finance"
  isUniversal  Boolean   @default(false) // Part of core framework
  icon         String?
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  templateModules      TemplateModule[]
  organizationModules  OrganizationModule[]
  tasks                Task[]
}

model TemplateModule {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  moduleId   String
  module     Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  isRequired Boolean  @default(false) // Some modules are mandatory for the template
  sortOrder  Int      @default(0)

  @@unique([templateId, moduleId])
}

enum ModuleStatus {
  INACTIVE
  SETUP_IN_PROGRESS
  ACTIVE
  PAUSED
}

model OrganizationModule {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  moduleId       String
  module         Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  status         ModuleStatus @default(INACTIVE)
  activatedAt    DateTime?
  configuration  Json?        // Module-specific settings
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, moduleId])
}

// ============================================================================
// CRM — CLIENTS & CONTACTS
// ============================================================================

enum ClientStatus {
  LEAD
  PROSPECT
  ACTIVE
  INACTIVE
  CHURNED
}

model Client {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  zip            String?
  status         ClientStatus @default(LEAD)
  notes          String?
  tags           String[]     // Flexible tagging
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  invoices       Invoice[]
  tasks          Task[]
  contacts       Contact[]

  @@index([organizationId])
  @@index([status])
}

model Contact {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  role      String?  // e.g., "Property Manager", "Office Admin"
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

// ============================================================================
// EMPLOYEES / WORKFORCE
// ============================================================================

model Employee {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  phone          String?
  role           String       // e.g., "Technician", "Dispatcher", "Foreman"
  department     String?
  hireDate       DateTime?
  hourlyRate     Float?
  isActive       Boolean      @default(true)
  skills         String[]     // e.g., ["HVAC", "Residential", "Commercial"]
  certifications String[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
}

// ============================================================================
// PROJECT MANAGEMENT / TASKS
// ============================================================================

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  dueDate        DateTime?
  completedAt    DateTime?
  estimatedHours Float?
  actualHours    Float?

  // Relations
  assigneeId     String?
  assignee       User?        @relation("AssignedTo", fields: [assigneeId], references: [id])
  createdById    String?
  createdBy      User?        @relation("CreatedBy", fields: [createdById], references: [id])
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id])
  moduleId       String?
  module         Module?      @relation(fields: [moduleId], references: [id])

  tags           String[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([assigneeId])
}

// ============================================================================
// INVOICING & PAYMENTS
// ============================================================================

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id])
  createdById    String
  createdBy      User          @relation(fields: [createdById], references: [id])

  invoiceNumber  String
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime      @default(now())
  dueDate        DateTime
  subtotal       Float         @default(0)
  taxRate        Float         @default(0)
  taxAmount      Float         @default(0)
  total          Float         @default(0)
  amountPaid     Float         @default(0)
  notes          String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  lineItems      InvoiceLineItem[]
  payments       Payment[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([status])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  total       Float
  sortOrder   Int     @default(0)
}

model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount      Float
  method      String   // "credit_card", "bank_transfer", "check", "cash"
  reference   String?  // Stripe payment intent ID, check number, etc.
  paidAt      DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([invoiceId])
}

// ============================================================================
// ACTIVITY LOG (Audit Trail)
// ============================================================================

model ActivityLog {
  id             String       @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  userId         String?
  user           User?        @relation(fields: [userId], references: [id])
  action         String       // e.g., "module.activated", "invoice.sent", "client.created"
  entityType     String?      // e.g., "Invoice", "Client", "Module"
  entityId       String?
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
}
