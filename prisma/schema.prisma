// A1NT — A1 Integrations Business Operations Platform
// Core data models for CRM, project management, invoicing, and module system

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// AUTH & USERS
// ============================================================================

enum UserRole {
  SUPER_ADMIN    // A1 Integrations staff
  OWNER          // Client business owner
  ADMIN          // Client admin user
  MANAGER        // Client manager
  EMPLOYEE       // Client employee / technician
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  role          UserRole  @default(EMPLOYEE)
  avatarUrl     String?
  phone         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  assignedTasks  Task[]        @relation("AssignedTo")
  createdTasks   Task[]        @relation("CreatedBy")
  invoicesCreated Invoice[]
  activityLogs   ActivityLog[]
  sessions       Session[]

  @@index([organizationId])
  @@index([email])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
}

// ============================================================================
// ORGANIZATIONS (Client Businesses)
// ============================================================================

enum IndustryType {
  PLUMBING_HVAC
  AUTO_REPAIR
  RESTAURANT
  CLEANING_SERVICE
  LANDSCAPING
  MANUFACTURING
  WHOLESALE_DISTRIBUTION
  LODGING_HOSPITALITY
  GAS_STATION_CSTORE
  BOOKKEEPING_ACCOUNTING
  OTHER
}

model Organization {
  id            String       @id @default(cuid())
  name          String
  industry      IndustryType
  description   String?
  phone         String?
  email         String?
  website       String?
  address       String?
  city          String?
  state         String?
  zip           String?
  employeeCount Int?
  annualRevenue Float?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Template & module configuration
  templateId    String?
  template      Template?    @relation(fields: [templateId], references: [id])

  // Relations
  users              User[]
  clients            Client[]
  employees          Employee[]
  invoices           Invoice[]
  tasks              Task[]
  workOrders         WorkOrder[]
  scheduleEvents     ScheduleEvent[]
  modules            OrganizationModule[]
  activityLogs       ActivityLog[]
  callRecords        CallRecord[]
  outboundQueueItems OutboundQueueItem[]
  routingRules       RoutingRule[]
  routingOverrides   RoutingOverride[]
  customRoutingRules CustomRoutingRule[]
  routingSchedule    RoutingScheduleBlock[]

  @@index([industry])
}

// ============================================================================
// TEMPLATES & MODULES (Core A1NT Product)
// ============================================================================

model Template {
  id           String    @id @default(cuid())
  name         String    // e.g., "Plumbing & HVAC Services"
  slug         String    @unique
  industry     IndustryType
  description  String?
  version      String    @default("1.0.0")
  isPublished  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  modules       TemplateModule[]
  organizations Organization[]
}

model Module {
  id           String    @id @default(cuid())
  name         String    // e.g., "AI Receptionist & Call Handling"
  slug         String    @unique
  description  String?
  category     String    // e.g., "Communication", "Operations", "Finance"
  isUniversal  Boolean   @default(false) // Part of core framework
  icon         String?
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  templateModules      TemplateModule[]
  organizationModules  OrganizationModule[]
  tasks                Task[]
}

model TemplateModule {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  moduleId   String
  module     Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  isRequired Boolean  @default(false) // Some modules are mandatory for the template
  sortOrder  Int      @default(0)

  @@unique([templateId, moduleId])
}

enum ModuleStatus {
  INACTIVE
  SETUP_IN_PROGRESS
  ACTIVE
  PAUSED
}

model OrganizationModule {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  moduleId       String
  module         Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  status         ModuleStatus @default(INACTIVE)
  activatedAt    DateTime?
  configuration  Json?        // Module-specific settings
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, moduleId])
}

// ============================================================================
// CRM — CLIENTS & CONTACTS
// ============================================================================

enum ClientStatus {
  LEAD
  PROSPECT
  ACTIVE
  INACTIVE
  CHURNED
}

model Client {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  zip            String?
  status         ClientStatus @default(LEAD)
  notes          String?
  tags           String[]     // Flexible tagging
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  invoices       Invoice[]
  tasks          Task[]
  workOrders     WorkOrder[]
  scheduleEvents ScheduleEvent[]
  contacts       Contact[]
  callRecords    CallRecord[]

  @@index([organizationId])
  @@index([status])
}

model Contact {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  role      String?  // e.g., "Property Manager", "Office Admin"
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

// ============================================================================
// EMPLOYEES / WORKFORCE
// ============================================================================

model Employee {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  phone          String?
  role           String       // e.g., "Technician", "Dispatcher", "Foreman"
  department     String?
  hireDate       DateTime?
  hourlyRate     Float?
  isActive       Boolean      @default(true)
  skills         String[]     // e.g., ["HVAC", "Residential", "Commercial"]
  certifications String[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  workOrders     WorkOrder[]
  scheduleEvents ScheduleEvent[]

  @@index([organizationId])
}

// ============================================================================
// WORK ORDERS & JOB TRACKING
// ============================================================================

enum WorkOrderStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  INVOICED
  CANCELLED
}

enum WorkOrderPriority {
  LOW
  NORMAL
  HIGH
  EMERGENCY
}

model WorkOrder {
  id              String            @id @default(cuid())
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orderNumber     String            // e.g., "WO-1084"
  title           String
  description     String?
  status          WorkOrderStatus   @default(NEW)
  priority        WorkOrderPriority @default(NORMAL)
  serviceType     String?           // e.g., "HVAC Repair", "Plumbing Install"

  // Assignment
  assigneeId      String?
  assignee        Employee?         @relation(fields: [assigneeId], references: [id])

  // Client
  clientId        String?
  client          Client?           @relation(fields: [clientId], references: [id])
  serviceAddress  String?

  // Scheduling
  scheduledStart  DateTime?
  scheduledEnd    DateTime?
  actualStart     DateTime?
  actualEnd       DateTime?
  estimatedHours  Float?
  actualHours     Float?

  // Materials & costs
  materialsUsed   Json?             // Array of { item, quantity, cost }
  laborCost       Float?            @default(0)
  materialCost    Float?            @default(0)
  totalCost       Float?            @default(0)

  // Documentation
  notes           String?
  internalNotes   String?
  photos          String[]          // URLs to uploaded photos

  // Completion
  completedAt     DateTime?
  completedById   String?

  // Invoice link
  invoiceId       String?
  invoice         Invoice?          @relation(fields: [invoiceId], references: [id])

  // Metadata
  tags            String[]
  customFields    Json?             // Template-specific fields (VIN, unit model, etc.)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  scheduleEvents  ScheduleEvent[]
  callRecords     CallRecord[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId])
  @@index([status])
  @@index([assigneeId])
  @@index([clientId])
}

// ============================================================================
// SCHEDULING & DISPATCHING
// ============================================================================

enum ScheduleEventType {
  JOB            // Linked to a work order
  APPOINTMENT    // Client appointment (no work order yet)
  BLOCK          // Blocked time (PTO, meeting, break)
  RECURRING      // Recurring maintenance/service
}

model ScheduleEvent {
  id              String             @id @default(cuid())
  organizationId  String
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  eventType       ScheduleEventType  @default(JOB)

  // Timing
  startTime       DateTime
  endTime         DateTime
  allDay          Boolean            @default(false)

  // Assignment
  assigneeId      String?
  assignee        Employee?          @relation(fields: [assigneeId], references: [id])

  // Link to work order (if JOB type)
  workOrderId     String?
  workOrder       WorkOrder?         @relation(fields: [workOrderId], references: [id])

  // Client context
  clientId        String?
  client          Client?            @relation(fields: [clientId], references: [id])
  location        String?

  // Recurrence
  isRecurring     Boolean            @default(false)
  recurrenceRule  String?            // iCal RRULE format

  // Status
  isCancelled     Boolean            @default(false)
  notes           String?

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([organizationId])
  @@index([assigneeId])
  @@index([startTime])
}

// ============================================================================
// PROJECT MANAGEMENT / TASKS
// ============================================================================

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  dueDate        DateTime?
  completedAt    DateTime?
  estimatedHours Float?
  actualHours    Float?

  // Relations
  assigneeId     String?
  assignee       User?        @relation("AssignedTo", fields: [assigneeId], references: [id])
  createdById    String?
  createdBy      User?        @relation("CreatedBy", fields: [createdById], references: [id])
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id])
  moduleId       String?
  module         Module?      @relation(fields: [moduleId], references: [id])

  tags           String[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([assigneeId])
}

// ============================================================================
// INVOICING & PAYMENTS
// ============================================================================

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id])
  createdById    String
  createdBy      User          @relation(fields: [createdById], references: [id])

  invoiceNumber  String
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime      @default(now())
  dueDate        DateTime
  subtotal       Float         @default(0)
  taxRate        Float         @default(0)
  taxAmount      Float         @default(0)
  total          Float         @default(0)
  amountPaid     Float         @default(0)
  notes          String?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  lineItems      InvoiceLineItem[]
  payments       Payment[]
  workOrders     WorkOrder[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([status])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  total       Float
  sortOrder   Int     @default(0)
}

model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount      Float
  method      String   // "credit_card", "bank_transfer", "check", "cash"
  reference   String?  // Stripe payment intent ID, check number, etc.
  paidAt      DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([invoiceId])
}

// ============================================================================
// AI VOICE CALLS & RECEPTIONIST
// ============================================================================

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  ACTIVE
  COMPLETED
  VOICEMAIL
  MISSED
  TRANSFERRED
  FAILED
}

enum CallIntent {
  SERVICE_REQUEST
  APPOINTMENT
  BILLING
  EMERGENCY
  GENERAL
  SALES_INQUIRY
}

enum CallPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum CallSentiment {
  POSITIVE
  NEUTRAL
  FRUSTRATED
}

model CallRecord {
  id              String         @id @default(cuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Twilio metadata
  callSid         String         @unique // Twilio Call SID — unique per call
  streamSid       String?        // Twilio Media Stream SID

  // Caller info
  callerNumber    String
  callerName      String?
  callerCity      String?
  callerState     String?

  // Call properties
  direction       CallDirection  @default(INBOUND)
  status          CallStatus     @default(ACTIVE)
  intent          CallIntent?
  priority        CallPriority   @default(NORMAL)
  sentiment       CallSentiment?

  // Timing
  startedAt       DateTime       @default(now())
  endedAt         DateTime?
  duration        Int            @default(0) // seconds

  // AI Agent
  agentId         String         @default("agent-alex")
  agentName       String         @default("Alex")
  model           String         @default("gpt-realtime-mini")
  voice           String         @default("alloy")

  // Conversation data (JSONB)
  transcript      Json?          // Array of { speaker, text, timestamp }
  summary         String?        // AI-generated call summary
  toolCalls       Json?          // Array of { id, name, arguments, output, timestamp, durationMs }
  actionsTaken    String[]       // Human-readable action list

  // Linked items created during the call
  workOrderId     String?        // FK to WorkOrder created during call
  workOrder       WorkOrder?     @relation(fields: [workOrderId], references: [id])
  clientId        String?        // FK to Client (existing or newly created)
  client          Client?        @relation(fields: [clientId], references: [id])
  appointmentBooked Boolean      @default(false)
  isNewCustomer   Boolean        @default(false)

  // Usage tracking
  tokensInput     Int            @default(0)
  tokensOutput    Int            @default(0)
  tokensTotal     Int            @default(0)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([startedAt])
  @@index([callerNumber])
  @@index([intent])
}

// ============================================================================
// ACTIVITY LOG (Audit Trail)
// ============================================================================

// ============================================================================
// OPERATOR MODULE — Outbound Queue
// ============================================================================

enum OutboundQueueStatus {
  QUEUED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

enum OutboundCampaignType {
  APPOINTMENT_CONFIRM
  APPOINTMENT_RESCHEDULE
  PRE_SERVICE_INFO
  POST_SERVICE_FOLLOWUP
  INVOICE_FOLLOWUP
  SEASONAL_PROMO
  SALES_PROSPECTING
  CUSTOM
}

enum OutboundCallPriority {
  NORMAL
  HIGH
  URGENT
}

enum OutboundCallOutcome {
  ANSWERED
  VOICEMAIL
  NO_ANSWER
  BUSY
  DECLINED
  WRONG_NUMBER
}

model OutboundQueueItem {
  id                String                @id @default(cuid())
  organizationId    String
  organization      Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Contact info
  contactName       String
  contactPhone      String

  // Campaign config
  campaignType      OutboundCampaignType
  assignedAgentId   String?
  assignedAgentName String?
  notes             String                @default("")
  contextData       Json?                 // Campaign-specific context for the AI agent

  // Status tracking
  status            OutboundQueueStatus   @default(QUEUED)
  priority          OutboundCallPriority  @default(NORMAL)
  outcome           OutboundCallOutcome?

  // Scheduling
  scheduledTime     DateTime?
  queuedAt          DateTime              @default(now())
  startedAt         DateTime?
  completedAt       DateTime?
  duration          Int?                  // seconds

  // Retry management
  retryCount        Int                   @default(0)
  maxRetries        Int                   @default(3)

  // Link to actual call record (created when call starts)
  callRecordId      String?               @unique

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([priority])
  @@index([scheduledTime])
}

// ============================================================================
// OPERATOR MODULE — Inbound Routing
// ============================================================================

enum RoutingMode {
  NORMAL
  OVERRIDE
  EMERGENCY
}

enum RoutingDestinationType {
  AI_RECEPTIONIST
  AI_RECEPTIONIST_LIMITED
  HUMAN
  VOICEMAIL
  IVR_MENU
  EMERGENCY_ONLY
  FORWARD_CELL
  FORWARD_EMPLOYEE
}

model RoutingRule {
  id                  String                @id @default(cuid())
  organizationId      String
  organization        Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name                String
  intent              String                // Maps to CallIntent
  businessHoursRoute  String
  afterHoursRoute     String
  priority            String                @default("normal") // low, normal, high, urgent
  enabled             Boolean               @default(true)
  sortOrder           Int                   @default(0)

  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([organizationId])
}

model RoutingOverride {
  id                String                @id @default(cuid())
  organizationId    String
  organization      Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  active            Boolean               @default(false)
  mode              RoutingMode           @default(NORMAL)
  destination       RoutingDestinationType @default(AI_RECEPTIONIST)
  forwardToNumber   String?
  forwardToName     String?
  reason            String                @default("")
  activatedAt       DateTime?
  expiresAt         DateTime?
  activatedBy       String                @default("")

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([organizationId])
}

model CustomRoutingRule {
  id                String                @id @default(cuid())
  organizationId    String
  organization      Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  type              String                // "area-code", "specific-number", "caller-id"
  match             String                // The area code or phone number to match
  destination       RoutingDestinationType
  forwardTo         String?
  voicemailMessage  String?
  expiresAt         DateTime?
  enabled           Boolean               @default(true)
  note              String                @default("")

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([organizationId])
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

model RoutingScheduleBlock {
  id                String                @id @default(cuid())
  organizationId    String
  organization      Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  day               DayOfWeek
  startHour         Int                   // 0-23
  endHour           Int                   // 0-23
  destination       RoutingDestinationType
  label             String
  agentScript       String?
  forwardToNumber   String?
  forwardToName     String?

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([organizationId])
  @@index([day])
}

// ============================================================================
// ACTIVITY LOG (Audit Trail)
// ============================================================================

model ActivityLog {
  id             String       @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  userId         String?
  user           User?        @relation(fields: [userId], references: [id])
  action         String       // e.g., "module.activated", "invoice.sent", "client.created"
  entityType     String?      // e.g., "Invoice", "Client", "Module"
  entityId       String?
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
}
