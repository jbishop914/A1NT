// A1NT — A1 Integrations Business Operations Platform
// Core data models for CRM, project management, invoicing, and module system

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// AUTH & USERS
// ============================================================================

enum UserRole {
  SUPER_ADMIN    // A1 Integrations staff
  OWNER          // Client business owner
  ADMIN          // Client admin user
  MANAGER        // Client manager
  EMPLOYEE       // Client employee / technician
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  role          UserRole  @default(EMPLOYEE)
  avatarUrl     String?
  phone         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  assignedTasks  Task[]        @relation("AssignedTo")
  createdTasks   Task[]        @relation("CreatedBy")
  invoicesCreated Invoice[]
  activityLogs   ActivityLog[]
  sessions       Session[]

  @@index([organizationId])
  @@index([email])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
}

// ============================================================================
// ORGANIZATIONS (Client Businesses)
// ============================================================================

enum IndustryType {
  PLUMBING_HVAC
  AUTO_REPAIR
  RESTAURANT
  CLEANING_SERVICE
  LANDSCAPING
  MANUFACTURING
  WHOLESALE_DISTRIBUTION
  LODGING_HOSPITALITY
  GAS_STATION_CSTORE
  BOOKKEEPING_ACCOUNTING
  OTHER
}

model Organization {
  id            String       @id @default(cuid())
  name          String
  industry      IndustryType
  description   String?
  phone         String?
  email         String?
  website       String?
  address       String?
  city          String?
  state         String?
  zip           String?
  employeeCount Int?
  annualRevenue Float?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Template & module configuration
  templateId    String?
  template      Template?    @relation(fields: [templateId], references: [id])

  // Service area (GeoJSON)
  serviceAreaType    ServiceAreaType?     // RADIUS or POLYGON
  serviceAreaRadius  Float?               // miles (if RADIUS type)
  serviceAreaCenter  Json?                // {lat, lng} center point
  serviceAreaPolygon Json?                // GeoJSON polygon coordinates
  businessHours      Json?                // {mon: {open: "08:00", close: "17:00"}, ...}

  // Relations
  users              User[]
  clients            Client[]
  employees          Employee[]
  invoices           Invoice[]
  tasks              Task[]
  workOrders         WorkOrder[]
  scheduleEvents     ScheduleEvent[]
  modules            OrganizationModule[]
  activityLogs       ActivityLog[]
  callRecords        CallRecord[]
  outboundQueueItems OutboundQueueItem[]
  routingRules       RoutingRule[]
  routingOverrides   RoutingOverride[]
  customRoutingRules CustomRoutingRule[]
  routingSchedule    RoutingScheduleBlock[]
  bookings           Booking[]
  bookingTypes       BookingType[]
  bookingFlags       BookingFlag[]
  stripeAccount      StripeAccount?
  emailDomains       EmailDomain[]
  emailLogs          EmailLog[]
  emailTemplates     EmailTemplate[]
  emailCampaigns     EmailCampaign[]
  emailContacts      EmailContact[]
  notificationPrefs  NotificationPreference[]
  smsLogs            SmsLog[]
  smsTemplates       SmsTemplate[]

  @@index([industry])
}

// ============================================================================
// TEMPLATES & MODULES (Core A1NT Product)
// ============================================================================

model Template {
  id           String    @id @default(cuid())
  name         String    // e.g., "Plumbing & HVAC Services"
  slug         String    @unique
  industry     IndustryType
  description  String?
  version      String    @default("1.0.0")
  isPublished  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  modules       TemplateModule[]
  organizations Organization[]
}

model Module {
  id           String    @id @default(cuid())
  name         String    // e.g., "AI Receptionist & Call Handling"
  slug         String    @unique
  description  String?
  category     String    // e.g., "Communication", "Operations", "Finance"
  isUniversal  Boolean   @default(false) // Part of core framework
  icon         String?
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  templateModules      TemplateModule[]
  organizationModules  OrganizationModule[]
  tasks                Task[]
}

model TemplateModule {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  moduleId   String
  module     Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  isRequired Boolean  @default(false) // Some modules are mandatory for the template
  sortOrder  Int      @default(0)

  @@unique([templateId, moduleId])
}

enum ModuleStatus {
  INACTIVE
  SETUP_IN_PROGRESS
  ACTIVE
  PAUSED
}

model OrganizationModule {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  moduleId       String
  module         Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  status         ModuleStatus @default(INACTIVE)
  activatedAt    DateTime?
  configuration  Json?        // Module-specific settings
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, moduleId])
}

// ============================================================================
// CRM — CLIENTS & CONTACTS
// ============================================================================

enum ClientStatus {
  LEAD
  PROSPECT
  ACTIVE
  INACTIVE
  CHURNED
}

model Client {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  zip            String?
  status         ClientStatus @default(LEAD)
  notes          String?
  tags           String[]     // Flexible tagging
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  invoices       Invoice[]
  tasks          Task[]
  workOrders     WorkOrder[]
  scheduleEvents ScheduleEvent[]
  contacts       Contact[]
  callRecords    CallRecord[]
  bookings       Booking[]
  emailContacts  EmailContact[]

  @@index([organizationId])
  @@index([status])
}

model Contact {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  role      String?  // e.g., "Property Manager", "Office Admin"
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

// ============================================================================
// EMPLOYEES / WORKFORCE
// ============================================================================

model Employee {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  phone          String?
  role           String       // e.g., "Technician", "Dispatcher", "Foreman"
  department     String?
  hireDate       DateTime?
  hourlyRate     Float?
  isActive       Boolean      @default(true)
  skills         String[]     // e.g., ["HVAC", "Residential", "Commercial"]
  certifications String[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relations
  workOrders     WorkOrder[]
  scheduleEvents ScheduleEvent[]
  bookingTypes   BookingType[]
  bookings       Booking[]

  @@index([organizationId])
}

// ============================================================================
// WORK ORDERS & JOB TRACKING
// ============================================================================

enum WorkOrderStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  INVOICED
  CANCELLED
}

enum WorkOrderPriority {
  LOW
  NORMAL
  HIGH
  EMERGENCY
}

model WorkOrder {
  id              String            @id @default(cuid())
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orderNumber     String            // e.g., "WO-1084"
  title           String
  description     String?
  status          WorkOrderStatus   @default(NEW)
  priority        WorkOrderPriority @default(NORMAL)
  serviceType     String?           // e.g., "HVAC Repair", "Plumbing Install"

  // Assignment
  assigneeId      String?
  assignee        Employee?         @relation(fields: [assigneeId], references: [id])

  // Client
  clientId        String?
  client          Client?           @relation(fields: [clientId], references: [id])
  serviceAddress  String?

  // Scheduling
  scheduledStart  DateTime?
  scheduledEnd    DateTime?
  actualStart     DateTime?
  actualEnd       DateTime?
  estimatedHours  Float?
  actualHours     Float?

  // Materials & costs
  materialsUsed   Json?             // Array of { item, quantity, cost }
  laborCost       Float?            @default(0)
  materialCost    Float?            @default(0)
  totalCost       Float?            @default(0)

  // Documentation
  notes           String?
  internalNotes   String?
  photos          String[]          // URLs to uploaded photos

  // Completion
  completedAt     DateTime?
  completedById   String?

  // Invoice link
  invoiceId       String?
  invoice         Invoice?          @relation(fields: [invoiceId], references: [id])

  // Metadata
  tags            String[]
  customFields    Json?             // Template-specific fields (VIN, unit model, etc.)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  scheduleEvents  ScheduleEvent[]
  callRecords     CallRecord[]
  bookings        Booking[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId])
  @@index([status])
  @@index([assigneeId])
  @@index([clientId])
}

// ============================================================================
// SCHEDULING & DISPATCHING
// ============================================================================

enum ScheduleEventType {
  JOB            // Linked to a work order
  APPOINTMENT    // Client appointment (no work order yet)
  BLOCK          // Blocked time (PTO, meeting, break)
  RECURRING      // Recurring maintenance/service
}

model ScheduleEvent {
  id              String             @id @default(cuid())
  organizationId  String
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  eventType       ScheduleEventType  @default(JOB)

  // Timing
  startTime       DateTime
  endTime         DateTime
  allDay          Boolean            @default(false)

  // Assignment
  assigneeId      String?
  assignee        Employee?          @relation(fields: [assigneeId], references: [id])

  // Link to work order (if JOB type)
  workOrderId     String?
  workOrder       WorkOrder?         @relation(fields: [workOrderId], references: [id])

  // Client context
  clientId        String?
  client          Client?            @relation(fields: [clientId], references: [id])
  location        String?

  // Recurrence
  isRecurring     Boolean            @default(false)
  recurrenceRule  String?            // iCal RRULE format

  // Status
  isCancelled     Boolean            @default(false)
  notes           String?

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  // Booking linkage
  bookings        Booking[]

  @@index([organizationId])
  @@index([assigneeId])
  @@index([startTime])
}

// ============================================================================
// PROJECT MANAGEMENT / TASKS
// ============================================================================

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(MEDIUM)
  dueDate        DateTime?
  completedAt    DateTime?
  estimatedHours Float?
  actualHours    Float?

  // Relations
  assigneeId     String?
  assignee       User?        @relation("AssignedTo", fields: [assigneeId], references: [id])
  createdById    String?
  createdBy      User?        @relation("CreatedBy", fields: [createdById], references: [id])
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id])
  moduleId       String?
  module         Module?      @relation(fields: [moduleId], references: [id])

  tags           String[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([assigneeId])
}

// ============================================================================
// STRIPE CONNECT (Platform Payments)
// ============================================================================

enum StripeAccountStatus {
  ONBOARDING       // Account created, onboarding not complete
  PENDING_REVIEW   // Onboarding submitted, Stripe reviewing
  ACTIVE           // Fully verified, can accept payments
  RESTRICTED       // Limited functionality (missing info or issues)
  DISABLED         // Manually disabled by platform or Stripe
}

model StripeAccount {
  id                String              @id @default(cuid())
  organizationId    String              @unique
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Stripe identifiers
  stripeAccountId   String              @unique // acct_xxx — Stripe Connect account ID
  stripeOnboardingComplete Boolean       @default(false)

  // Account status
  status            StripeAccountStatus @default(ONBOARDING)
  chargesEnabled    Boolean             @default(false)
  payoutsEnabled    Boolean             @default(false)
  detailsSubmitted  Boolean             @default(false)

  // Business info (cached from Stripe)
  businessName      String?
  businessType      String?             // "individual", "company", "non_profit"
  country           String              @default("US")
  defaultCurrency   String              @default("usd")

  // Platform fee config
  applicationFeePercent Float           @default(0.5)  // 0.5% platform fee
  applicationFeeFixed   Int             @default(25)   // $0.25 in cents

  // Payout schedule
  payoutScheduleInterval String         @default("daily") // daily, weekly, monthly
  payoutScheduleAnchor   Int?           // Day of week (1=Mon) or month (1-31)

  // Timestamps
  onboardingStartedAt DateTime?
  onboardingCompletedAt DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  // Relations
  paymentTransactions PaymentTransaction[]
  payouts             Payout[]

  @@index([stripeAccountId])
}

// ============================================================================
// INVOICING & PAYMENTS
// ============================================================================

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id])
  createdById    String
  createdBy      User          @relation(fields: [createdById], references: [id])

  invoiceNumber  String
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime      @default(now())
  dueDate        DateTime
  subtotal       Float         @default(0)
  taxRate        Float         @default(0)
  taxAmount      Float         @default(0)
  total          Float         @default(0)
  amountPaid     Float         @default(0)
  notes          String?
  paidAt         DateTime?

  // Stripe payment integration
  stripePaymentIntentId String?         // pi_xxx — for "Pay Now" link
  stripePaymentLink     String?         // URL for customer to pay online
  paymentLinkExpiresAt  DateTime?       // When the pay link expires

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  lineItems      InvoiceLineItem[]
  payments       Payment[]
  workOrders     WorkOrder[]
  transactions   PaymentTransaction[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([status])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float   @default(1)
  unitPrice   Float
  total       Float
  sortOrder   Int     @default(0)
}

model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount      Float
  method      String   // "credit_card", "bank_transfer", "check", "cash", "stripe"
  reference   String?  // Stripe payment intent ID, check number, etc.
  paidAt      DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([invoiceId])
}

// ============================================================================
// PAYMENT TRANSACTIONS (Stripe Ledger)
// ============================================================================

enum TransactionStatus {
  PENDING           // Payment intent created
  PROCESSING        // Payment being processed
  SUCCEEDED         // Payment captured successfully
  FAILED            // Payment attempt failed
  CANCELLED         // Payment intent cancelled
  REFUNDED          // Full refund processed
  PARTIALLY_REFUNDED // Partial refund
  DISPUTED          // Chargeback/dispute opened
}

enum TransactionType {
  INVOICE_PAYMENT   // Payment against an invoice
  BOOKING_PAYMENT   // Upfront service call payment
  DEPOSIT           // Deposit/partial payment
  REFUND            // Refund transaction
}

model PaymentTransaction {
  id                  String            @id @default(cuid())
  organizationId      String

  // Stripe identifiers
  stripeAccountId     String            // Connected account that received the payment
  stripeAccount       StripeAccount     @relation(fields: [stripeAccountId], references: [stripeAccountId])
  stripePaymentIntentId String?         @unique // pi_xxx
  stripeChargeId      String?           // ch_xxx
  stripeRefundId      String?           // re_xxx (for refund transactions)

  // Transaction details
  type                TransactionType
  status              TransactionStatus @default(PENDING)
  currency            String            @default("usd")
  amount              Int               // Total in cents (e.g., 50000 = $500.00)
  stripeFee           Int               @default(0) // Stripe processing fee in cents
  applicationFee      Int               @default(0) // A1NT platform fee in cents
  netAmount           Int               @default(0) // Amount to connected account in cents

  // Customer info
  customerName        String?
  customerEmail       String?
  paymentMethod       String?           // "card", "us_bank_account", "link"
  cardBrand           String?           // "visa", "mastercard", "amex"
  cardLast4           String?           // "4242"

  // Linked records
  invoiceId           String?
  invoice             Invoice?          @relation(fields: [invoiceId], references: [id])
  bookingId           String?
  booking             Booking?          @relation(fields: [bookingId], references: [id])

  // Metadata
  description         String?
  failureReason       String?           // Why payment failed
  refundReason        String?           // Why refund was issued
  metadata            Json?             // Additional Stripe metadata

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([organizationId])
  @@index([stripeAccountId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

// ============================================================================
// PAYOUTS (Stripe → Connected Account Bank)
// ============================================================================

enum PayoutStatus {
  PENDING
  IN_TRANSIT
  PAID
  FAILED
  CANCELLED
}

model Payout {
  id                  String        @id @default(cuid())
  organizationId      String

  // Stripe identifiers
  stripeAccountId     String
  stripeAccount       StripeAccount @relation(fields: [stripeAccountId], references: [stripeAccountId])
  stripePayoutId      String        @unique // po_xxx

  // Payout details
  status              PayoutStatus  @default(PENDING)
  amount              Int           // In cents
  currency            String        @default("usd")
  arrivalDate         DateTime      // Expected arrival
  method              String        @default("standard") // "standard" or "instant"

  // Bank info (masked)
  bankName            String?
  bankLast4           String?       // Last 4 of bank account

  // Metadata
  description         String?
  failureReason       String?

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([organizationId])
  @@index([stripeAccountId])
  @@index([status])
  @@index([arrivalDate])
}

// ============================================================================
// AI VOICE CALLS & RECEPTIONIST
// ============================================================================

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  ACTIVE
  COMPLETED
  VOICEMAIL
  MISSED
  TRANSFERRED
  FAILED
}

enum CallIntent {
  SERVICE_REQUEST
  APPOINTMENT
  BILLING
  EMERGENCY
  GENERAL
  SALES_INQUIRY
}

enum CallPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum CallSentiment {
  POSITIVE
  NEUTRAL
  FRUSTRATED
}

model CallRecord {
  id              String         @id @default(cuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Twilio metadata
  callSid         String         @unique // Twilio Call SID — unique per call
  streamSid       String?        // Twilio Media Stream SID

  // Caller info
  callerNumber    String
  callerName      String?
  callerCity      String?
  callerState     String?

  // Call properties
  direction       CallDirection  @default(INBOUND)
  status          CallStatus     @default(ACTIVE)
  intent          CallIntent?
  priority        CallPriority   @default(NORMAL)
  sentiment       CallSentiment?

  // Timing
  startedAt       DateTime       @default(now())
  endedAt         DateTime?
  duration        Int            @default(0) // seconds

  // AI Agent
  agentId         String         @default("agent-alex")
  agentName       String         @default("Alex")
  model           String         @default("gpt-realtime-mini")
  voice           String         @default("alloy")

  // Conversation data (JSONB)
  transcript      Json?          // Array of { speaker, text, timestamp }
  summary         String?        // AI-generated call summary
  toolCalls       Json?          // Array of { id, name, arguments, output, timestamp, durationMs }
  actionsTaken    String[]       // Human-readable action list

  // Linked items created during the call
  workOrderId     String?        // FK to WorkOrder created during call
  workOrder       WorkOrder?     @relation(fields: [workOrderId], references: [id])
  clientId        String?        // FK to Client (existing or newly created)
  client          Client?        @relation(fields: [clientId], references: [id])
  appointmentBooked Boolean      @default(false)
  isNewCustomer   Boolean        @default(false)

  // Usage tracking
  tokensInput     Int            @default(0)
  tokensOutput    Int            @default(0)
  tokensTotal     Int            @default(0)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([startedAt])
  @@index([callerNumber])
  @@index([intent])
}

// ============================================================================
// ACTIVITY LOG (Audit Trail)
// ============================================================================

// ============================================================================
// OPERATOR MODULE — Outbound Queue
// ============================================================================

enum OutboundQueueStatus {
  QUEUED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

enum OutboundCampaignType {
  APPOINTMENT_CONFIRM
  APPOINTMENT_RESCHEDULE
  PRE_SERVICE_INFO
  POST_SERVICE_FOLLOWUP
  INVOICE_FOLLOWUP
  SEASONAL_PROMO
  SALES_PROSPECTING
  CUSTOM
}

enum OutboundCallPriority {
  NORMAL
  HIGH
  URGENT
}

enum OutboundCallOutcome {
  ANSWERED
  VOICEMAIL
  NO_ANSWER
  BUSY
  DECLINED
  WRONG_NUMBER
}

model OutboundQueueItem {
  id                String                @id @default(cuid())
  organizationId    String
  organization      Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Contact info
  contactName       String
  contactPhone      String

  // Campaign config
  campaignType      OutboundCampaignType
  assignedAgentId   String?
  assignedAgentName String?
  notes             String                @default("")
  contextData       Json?                 // Campaign-specific context for the AI agent

  // Status tracking
  status            OutboundQueueStatus   @default(QUEUED)
  priority          OutboundCallPriority  @default(NORMAL)
  outcome           OutboundCallOutcome?

  // Scheduling
  scheduledTime     DateTime?
  queuedAt          DateTime              @default(now())
  startedAt         DateTime?
  completedAt       DateTime?
  duration          Int?                  // seconds

  // Retry management
  retryCount        Int                   @default(0)
  maxRetries        Int                   @default(3)

  // Link to actual call record (created when call starts)
  callRecordId      String?               @unique

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([priority])
  @@index([scheduledTime])
}

// ============================================================================
// OPERATOR MODULE — Inbound Routing
// ============================================================================

enum RoutingMode {
  NORMAL
  OVERRIDE
  EMERGENCY
}

enum RoutingDestinationType {
  AI_RECEPTIONIST
  AI_RECEPTIONIST_LIMITED
  HUMAN
  VOICEMAIL
  IVR_MENU
  EMERGENCY_ONLY
  FORWARD_CELL
  FORWARD_EMPLOYEE
}

model RoutingRule {
  id                  String                @id @default(cuid())
  organizationId      String
  organization        Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name                String
  intent              String                // Maps to CallIntent
  businessHoursRoute  String
  afterHoursRoute     String
  priority            String                @default("normal") // low, normal, high, urgent
  enabled             Boolean               @default(true)
  sortOrder           Int                   @default(0)

  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([organizationId])
}

model RoutingOverride {
  id                String                @id @default(cuid())
  organizationId    String
  organization      Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  active            Boolean               @default(false)
  mode              RoutingMode           @default(NORMAL)
  destination       RoutingDestinationType @default(AI_RECEPTIONIST)
  forwardToNumber   String?
  forwardToName     String?
  reason            String                @default("")
  activatedAt       DateTime?
  expiresAt         DateTime?
  activatedBy       String                @default("")

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([organizationId])
}

model CustomRoutingRule {
  id                String                @id @default(cuid())
  organizationId    String
  organization      Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  type              String                // "area-code", "specific-number", "caller-id"
  match             String                // The area code or phone number to match
  destination       RoutingDestinationType
  forwardTo         String?
  voicemailMessage  String?
  expiresAt         DateTime?
  enabled           Boolean               @default(true)
  note              String                @default("")

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([organizationId])
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

model RoutingScheduleBlock {
  id                String                @id @default(cuid())
  organizationId    String
  organization      Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  day               DayOfWeek
  startHour         Int                   // 0-23
  endHour           Int                   // 0-23
  destination       RoutingDestinationType
  label             String
  agentScript       String?
  forwardToNumber   String?
  forwardToName     String?

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([organizationId])
  @@index([day])
}

// ============================================================================
// ONLINE BOOKING SYSTEM
// ============================================================================

enum ServiceAreaType {
  RADIUS
  POLYGON
}

enum BookingStatus {
  PENDING       // Submitted, not yet confirmed
  CONFIRMED     // Confirmed by office/auto-confirmed
  SCHEDULED     // Linked to a ScheduleEvent
  COMPLETED     // Appointment completed
  CANCELLED     // Cancelled by customer or office
  NO_SHOW       // Customer didn't show
}

enum BookingTypeEnum {
  ESTIMATE
  FOLLOW_UP
  PRODUCT_DEMO
  SERVICE_CALL
  WARRANTY
}

model BookingType {
  id                String          @id @default(cuid())
  organizationId    String
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  type              BookingTypeEnum
  label             String          // Display name (customizable)
  durationMinutes   Int             // Default: 30, 30, 60, 60, 60
  description       String?         // Shown to customer
  isActive          Boolean         @default(true)
  color             String?         // For calendar display
  sortOrder         Int             @default(0)

  // Assignment rules
  autoAssign        Boolean         @default(false)
  assignToEmployeeId String?        // Default assignee if autoAssign
  assignToEmployee  Employee?       @relation(fields: [assignToEmployeeId], references: [id])

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  bookings          Booking[]

  @@unique([organizationId, type])
  @@index([organizationId])
}

model Booking {
  id                String          @id @default(cuid())
  organizationId    String
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Customer info (public — no auth required)
  customerName      String
  customerPhone     String
  customerEmail     String?
  serviceAddress    String
  serviceCity       String?
  serviceState      String?
  serviceZip        String?
  serviceLat        Float?          // Geocoded latitude
  serviceLng        Float?          // Geocoded longitude

  // Booking details
  bookingTypeId     String
  bookingType       BookingType     @relation(fields: [bookingTypeId], references: [id])
  requestedDate     DateTime        // Requested appointment date/time
  endTime           DateTime?       // Calculated from duration
  description       String?         // Customer description of work needed
  status            BookingStatus   @default(PENDING)

  // Auto-categorization
  detectedCategory  String?         // AI-categorized service type
  estimatedDuration Int?            // Override if AI suggests different duration

  // Linkage to internal records
  scheduleEventId   String?         // Linked ScheduleEvent once scheduled
  scheduleEvent     ScheduleEvent?  @relation(fields: [scheduleEventId], references: [id])
  workOrderId       String?         // Linked WorkOrder if one is created
  workOrder         WorkOrder?      @relation(fields: [workOrderId], references: [id])
  clientId          String?         // Linked Client if matched/created
  client            Client?         @relation(fields: [clientId], references: [id])
  assigneeId        String?         // Assigned tech/employee
  assignee          Employee?       @relation(fields: [assigneeId], references: [id])

  // Source tracking
  source            String          @default("widget") // "widget", "website", "api"
  widgetTheme       String?         // Which theme was used
  referrer          String?         // Referring URL

  // Confirmation
  confirmedAt       DateTime?
  confirmedBy       String?         // user ID or "auto"
  cancelledAt       DateTime?
  cancelReason      String?

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  flags             BookingFlag[]
  transactions      PaymentTransaction[]

  @@index([organizationId])
  @@index([requestedDate])
  @@index([status])
  @@index([customerPhone])
}

model BookingFlag {
  id                String          @id @default(cuid())
  organizationId    String
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookingId         String?
  booking           Booking?        @relation(fields: [bookingId], references: [id])

  flagType          String          // "out-of-service-area", "duplicate", "after-hours", "suspicious"
  description       String?
  serviceAddress    String?         // The address that was flagged
  isResolved        Boolean         @default(false)
  resolvedAt        DateTime?
  resolvedBy        String?
  resolvedNote      String?

  createdAt         DateTime        @default(now())

  @@index([organizationId])
  @@index([flagType])
}

// ============================================================================
// ACTIVITY LOG (Audit Trail)
// ============================================================================

model ActivityLog {
  id             String       @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  userId         String?
  user           User?        @relation(fields: [userId], references: [id])
  action         String       // e.g., "module.activated", "invoice.sent", "client.created"
  entityType     String?      // e.g., "Invoice", "Client", "Module"
  entityId       String?
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================================================
// EMAIL SYSTEM (Resend Integration)
// ============================================================================

enum EmailDomainStatus {
  PENDING         // Domain added, DNS records not yet configured
  VERIFYING       // DNS records added, verification in progress
  VERIFIED        // Domain fully verified and ready to send
  FAILED          // Verification failed
}

enum EmailLogStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  FAILED
}

enum EmailType {
  TRANSACTIONAL    // System-generated: invoices, confirmations, assignments
  MARKETING        // Campaign emails: newsletters, promotions
  NOTIFICATION     // Event-driven: new booking, payment received
  REMINDER         // Scheduled: annual service reminders, follow-ups
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

// Verified sending domains per organization
model EmailDomain {
  id               String            @id @default(cuid())
  organizationId   String
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  domain           String            // e.g., "notifications.clientbusiness.com"
  resendDomainId   String?           // Resend's domain ID for API calls
  status           EmailDomainStatus @default(PENDING)
  region           String            @default("us-east-1")

  // DNS records returned by Resend (stored for UI display)
  dnsRecords       Json?             // Array of {record, name, type, value, status}

  // Sender defaults for this domain
  defaultFromName  String?           // e.g., "Acme Plumbing"
  defaultFromEmail String?           // e.g., "noreply@notifications.clientbusiness.com"
  defaultReplyTo   String?           // e.g., "support@clientbusiness.com"

  verifiedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([organizationId, domain])
  @@index([organizationId])
  @@index([status])
}

// Every email sent through the platform
model EmailLog {
  id               String          @id @default(cuid())
  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  resendEmailId    String?         // Resend's email ID for tracking
  type             EmailType
  status           EmailLogStatus  @default(QUEUED)

  // Sender / recipient
  fromAddress      String
  toAddresses      Json            // string[] — can be multiple recipients
  ccAddresses      Json?           // string[]
  bccAddresses     Json?           // string[]
  replyTo          String?

  // Content
  subject          String
  templateId       String?         // Link to EmailTemplate if used
  template         EmailTemplate?  @relation(fields: [templateId], references: [id])
  campaignId       String?         // Link to EmailCampaign if part of one
  campaign         EmailCampaign?  @relation(fields: [campaignId], references: [id])

  // Context — what triggered this email
  triggerEvent     String?         // e.g., "invoice.created", "booking.confirmed"
  entityType       String?         // e.g., "Invoice", "Booking", "WorkOrder"
  entityId         String?         // ID of the related entity

  // Delivery tracking
  sentAt           DateTime?
  deliveredAt      DateTime?
  openedAt         DateTime?
  clickedAt        DateTime?
  bouncedAt        DateTime?
  bounceType       String?         // "Permanent" | "Transient"
  bounceMessage    String?
  complainedAt     DateTime?

  // Tags for filtering
  tags             Json?           // {key: value} pairs

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([organizationId])
  @@index([type])
  @@index([status])
  @@index([resendEmailId])
  @@index([triggerEvent])
  @@index([createdAt])
}

// Reusable email templates (React Email components stored as config)
model EmailTemplate {
  id               String          @id @default(cuid())
  organizationId   String?
  organization     Organization?   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name             String          // e.g., "Invoice Email", "Booking Confirmation"
  slug             String          // e.g., "invoice", "booking-confirmation"
  description      String?
  type             EmailType

  // Template content
  subject          String          // Default subject (can use {{variables}})
  bodyHtml         String?         // Raw HTML fallback
  bodyText         String?         // Plain text fallback
  variables        Json?           // Available variables: [{name, description, required}]

  // System templates have null organizationId (shared across all orgs)
  isSystem         Boolean         @default(false)
  isActive         Boolean         @default(true)

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  emailLogs        EmailLog[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([type])
  @@index([slug])
}

// Marketing campaigns (email, SMS, or both)
model EmailCampaign {
  id               String          @id @default(cuid())
  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name             String
  subject          String?         // Email subject (null for SMS-only)
  fromName         String?
  fromEmail        String?
  replyTo          String?

  // Channel
  channel          CampaignChannel @default(EMAIL) // EMAIL, SMS, or BOTH

  // Content — email
  bodyHtml         String?         // Composed HTML content for email
  emailTemplateId  String?         // Or use an email template

  // Content — SMS
  smsBody          String?         // SMS text body (max ~1600 chars)
  smsTemplateId    String?         // Or use an SMS template

  // Audience targeting
  audienceFilter   Json?           // Filter criteria: {status, tags, clientType, ...}
  recipientCount   Int             @default(0)

  // Scheduling
  status           CampaignStatus  @default(DRAFT)
  scheduledAt      DateTime?       // When to send (null = send immediately)
  sentAt           DateTime?
  completedAt      DateTime?

  // Stats — Email (updated via webhooks)
  totalSent        Int             @default(0)
  totalDelivered   Int             @default(0)
  totalOpened      Int             @default(0)
  totalClicked     Int             @default(0)
  totalBounced     Int             @default(0)
  totalComplaints  Int             @default(0)

  // Stats — SMS
  totalSmsSent     Int             @default(0)
  totalSmsDelivered Int            @default(0)
  totalSmsFailed   Int             @default(0)

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  emailLogs        EmailLog[]
  smsLogs          SmsLog[]

  @@index([organizationId])
  @@index([status])
  @@index([scheduledAt])
  @@index([channel])
}

// Email contacts / audience management
model EmailContact {
  id               String          @id @default(cuid())
  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  email            String
  firstName        String?
  lastName         String?
  phone            String?

  // Linked to CRM client if applicable
  clientId         String?
  client           Client?         @relation(fields: [clientId], references: [id])

  // Subscription status
  isSubscribed     Boolean         @default(true)
  unsubscribedAt   DateTime?
  unsubscribeReason String?

  // Segmentation tags
  tags             Json?           // string[] for audience segmentation
  metadata         Json?           // Custom properties for personalization

  // Resend contact ID (synced to Resend Audiences)
  resendContactId  String?

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([clientId])
  @@index([isSubscribed])
}

// Per-org notification preferences (which events trigger messages)
model NotificationPreference {
  id               String          @id @default(cuid())
  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Event type (matches triggerEvent in EmailLog/SmsLog)
  event            String          // e.g., "invoice.created", "booking.confirmed"
  description      String?         // Human-readable: "Send notification when a new invoice is created"

  // Toggle + channel
  isEnabled        Boolean         @default(true)
  sendEmail        Boolean         @default(true)   // Send via email
  sendSms          Boolean         @default(false)  // Send via SMS
  sendToClient     Boolean         @default(true)   // Send to the client/customer
  sendToAdmin      Boolean         @default(false)  // CC to org admin
  sendToAssignee   Boolean         @default(false)  // Send to assigned employee

  // Template overrides
  emailTemplateId  String?         // Custom email template for this event
  smsTemplateId    String?         // Custom SMS template for this event

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([organizationId, event])
  @@index([organizationId])
}

// ============================================================================
// SMS SYSTEM (Twilio Integration)
// ============================================================================

enum SmsLogStatus {
  QUEUED
  SENT
  DELIVERED
  UNDELIVERED
  FAILED
}

enum CampaignChannel {
  EMAIL
  SMS
  BOTH
}

// Every SMS sent through the platform
model SmsLog {
  id               String          @id @default(cuid())
  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  twilioMessageSid String?         // Twilio's message SID for tracking
  status           SmsLogStatus    @default(QUEUED)

  // Sender / recipient
  fromNumber       String          // Twilio phone number
  toNumber         String          // Recipient phone number

  // Content
  body             String          // SMS body (max 1600 chars with segments)
  segmentCount     Int             @default(1) // Number of SMS segments
  templateId       String?         // Link to SmsTemplate if used
  template         SmsTemplate?    @relation(fields: [templateId], references: [id])
  campaignId       String?         // Link to EmailCampaign if part of multi-channel campaign
  campaign         EmailCampaign?  @relation(fields: [campaignId], references: [id])

  // Context — what triggered this SMS
  triggerEvent     String?         // e.g., "booking.confirmed", "invoice.created"
  entityType       String?         // e.g., "Booking", "Invoice"
  entityId         String?

  // Delivery tracking
  sentAt           DateTime?
  deliveredAt      DateTime?
  errorCode        String?         // Twilio error code if failed
  errorMessage     String?

  // Cost tracking
  priceCents       Int?            // Twilio price in cents

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([twilioMessageSid])
  @@index([triggerEvent])
  @@index([createdAt])
}

// Reusable SMS templates
model SmsTemplate {
  id               String          @id @default(cuid())
  organizationId   String?
  organization     Organization?   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name             String          // e.g., "Booking Confirmation SMS"
  slug             String          // e.g., "booking-confirmation-sms"
  description      String?

  // Template content (supports {{variable}} placeholders)
  body             String          // SMS body template
  variables        Json?           // Available variables: [{name, description, required}]

  // System templates have null organizationId
  isSystem         Boolean         @default(false)
  isActive         Boolean         @default(true)

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  smsLogs          SmsLog[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([slug])
}
